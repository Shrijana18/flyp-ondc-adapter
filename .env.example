# ============================================
# FLYP ONDC Adapter — Environment Variables
# Copy to .env and fill in your values
# ============================================

# Server
PORT=3000
NODE_ENV=preprod

# ONDC Identity (your Subscriber ID = your domain)
SUBSCRIBER_ID=ondc.flypnow.in
SUBSCRIBER_URI=/ondc
UNIQUE_KEY_ID=flyp-key-1

# ONDC Network Endpoints (Preprod)
REGISTRY_URL=https://preprod.registry.ondc.org/ondc
GATEWAY_URL=https://preprod.gateway.ondc.org
BAP_CALLBACK_URL=https://preprod.gateway.ondc.org

# Ed25519 Keys (generate with: npm run generate-keys)
SIGNING_PRIVATE_KEY=
SIGNING_PUBLIC_KEY=
ENCRYPTION_PRIVATE_KEY=
ENCRYPTION_PUBLIC_KEY=

# Firebase Admin SDK (from Firebase Console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=stockpilotv1
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# City / Default Provider Config
DEFAULT_CITY_CODE=std:080
DEFAULT_COUNTRY_CODE=IND
DEFAULT_CURRENCY=INR
DEFAULT_TTL=PT30S
